---
/**
 * Schema.astro - Componente para generar structured data (JSON-LD)
 * Genera schema.org automáticamente
 */
import {
  generateOrganizationSchema,
  generateRestaurantSchema,
  generateLocalBusinessSchema,
  generateBreadcrumbSchema,
  generateFAQSchema,
  generateArticleSchema,
  mergeSchemas,
} from '@/lib/seo-utils'

export interface Props {
  type:
    | 'organization'
    | 'restaurant'
    | 'localBusiness'
    | 'breadcrumb'
    | 'faq'
    | 'article'
    | 'aggregate'

  // Para breadcrumb
  breadcrumbs?: Array<{ name: string; url: string }>

  // Para FAQ
  faqs?: Array<{ question: string; answer: string }>

  // Para article
  article?: {
    title: string
    description: string
    image: string
    publishedDate: Date
    modifiedDate?: Date
    author?: string
  }

  // Para aggregate (múltiples schemas)
  schemas?: Array<{
    type: 'organization' | 'restaurant' | 'localBusiness'
  }>

  // Additional custom schema
  customSchema?: Record<string, any>
}

const { type, breadcrumbs, faqs, article, schemas = [], customSchema } = Astro.props

let schema: Record<string, any> | null = null

// Generar schema según tipo
switch (type) {
  case 'organization':
    schema = generateOrganizationSchema()
    break
  case 'restaurant':
    schema = generateRestaurantSchema()
    break
  case 'localBusiness':
    schema = generateLocalBusinessSchema()
    break
  case 'breadcrumb':
    if (breadcrumbs) {
      schema = generateBreadcrumbSchema(breadcrumbs)
    }
    break
  case 'faq':
    if (faqs) {
      schema = generateFAQSchema(faqs)
    }
    break
  case 'article':
    if (article) {
      schema = generateArticleSchema(article)
    }
    break
  case 'aggregate': {
    const schemaSource =
      schemas.length > 0
        ? schemas
        : [
            { type: 'organization' as const },
            { type: 'restaurant' as const },
            { type: 'localBusiness' as const },
          ]

    const schemaList: Record<string, any>[] = []

    for (const s of schemaSource) {
      if (s.type === 'organization') {
        schemaList.push(generateOrganizationSchema())
      } else if (s.type === 'restaurant') {
        schemaList.push(generateRestaurantSchema())
      } else if (s.type === 'localBusiness') {
        schemaList.push(generateLocalBusinessSchema())
      }
    }

    if (schemaList.length > 0) {
      schema = mergeSchemas(schemaList)
    }
    break
  }
}

// Mergear custom schema si existe
if (customSchema && schema) {
  schema = { ...schema, ...customSchema }
}
---

{/* eslint-disable-next-line astro/no-set-html-directive */}
{schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
