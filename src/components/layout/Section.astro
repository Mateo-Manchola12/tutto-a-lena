---
interface Props {
  title?: string
  subtitle?: string
  center?: boolean
  className?: string
}
const { title, subtitle, center = false, className = '' } = Astro.props as Props
---

<section class={`py-12 md:py-16 ${className}`}>
  {
    (title || subtitle) && (
      <header class={`mb-6 ${center ? 'text-center' : ''}`}>
        {title && <h2 class="text-2xl md:text-3xl font-semibold text-foreground">{title}</h2>}
        {subtitle && <p class="text-muted mt-2">{subtitle}</p>}
      </header>
    )
  }
  <slot />
</section>
