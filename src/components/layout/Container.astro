---
interface Props {
  size?: 'sm' | 'md' | 'lg' | 'xl'
  className?: string
}
const { size = 'lg', className = '' } = Astro.props as Props

const maxWidth = {
  sm: 'max-w-screen-sm',
  md: 'max-w-screen-md',
  lg: 'max-w-screen-lg',
  xl: 'max-w-screen-xl',
}[size]
---

<div class={`mx-auto w-full ${maxWidth} px-4 md:px-6 ${className}`}>
  <slot />
</div>
