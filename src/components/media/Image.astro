---
interface Props {
  src: string
  alt: string
  width?: number
  height?: number
  loading?: 'eager' | 'lazy'
  decoding?: 'auto' | 'async' | 'sync'
  className?: string
}
const {
  src,
  alt,
  width,
  height,
  loading = 'lazy',
  decoding = 'async',
  className = '',
} = Astro.props as Props
---

<img
  src={src}
  alt={alt}
  width={width}
  height={height}
  loading={loading}
  decoding={decoding}
  class={className}
/>
