---
import { Picture } from 'astro:assets'
import { Gallery as GalleryData } from '@/constants/gallery'

// ─── Datos desde Firestore ────────────────────────────────────────────────────
const images = await GalleryData.getFeatured(6)
---

<section class="py-16 md:py-20 bg-background">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-12 space-y-4">
      <h2 class="font-display text-4xl md:text-5xl font-bold text-foreground">
        Nuestra <span class="text-primary">Historia</span>
      </h2>
      <p class="font-handwriting text-xl md:text-2xl text-muted max-w-2xl mx-auto">
        Momentos de sabor y tradición
      </p>
    </div>

    <!-- Collage Grid — responsive masonry orgánico -->
    <div class="relative max-w-6xl mx-auto">
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 auto-rows-[200px] gap-4">
        {images.map((image, index) => {
          const spanClass = GalleryData.getSpanClass(image)
          return (
            <div
              class={`gallery-item ${spanClass} group cursor-pointer overflow-hidden rounded-3xl relative shadow-card hover:shadow-glow-strong transition-all duration-500`}
              style={`animation: fade-in-up 0.7s ease-out ${index * 100}ms forwards; opacity: 0;`}
            >
              <Picture
                src={image.src}
                alt={image.alt}
                formats={['avif', 'webp']}
                inferSize
                sizes="(max-width: 639px) 50vw, (max-width: 767px) 33vw, 25vw"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover transition-transform duration-700 ease-out"
                style={`transform: rotate(${image.rotate}deg) scale(1.04);`}
              />
              <!-- Overlay sutil en hover -->
              <div class="absolute inset-0 bg-linear-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
            </div>
          )
        })}
      </div>

      <!-- Botón para ver galería completa -->
      <div class="text-center mt-12">
        <a
          href="/galeria"
          class="inline-flex items-center gap-2 px-6 py-3 bg-surface-light hover:bg-surface-hover text-foreground rounded-lg transition-colors border border-surface-border"
        >
          Ver galería completa
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* El elemento <picture> generado por Astro debe llenar la celda del grid */
  .gallery-item :global(picture) {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Resetea la rotación orgánica y escala en hover */
  .gallery-item:hover :global(img) {
    transform: rotate(0deg) scale(1.1) !important;
  }
</style>

