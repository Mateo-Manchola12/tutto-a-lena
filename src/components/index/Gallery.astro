---
import { Picture } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import { Gallery } from '@/constants/gallery'

const images = await Gallery.getFeatured(6)

// Carga todos los archivos de public/images/ como ImageMetadata para que Astro
// los optimice (WebP + AVIF) en la build estática.
// Imágenes de Firebase Storage (URL https) también se optimizan via inferSize.
const localGlob = import.meta.glob<{ default: ImageMetadata }>(
  '/public/images/**/*.{jpg,jpeg,png,webp,avif}',
)
const localMap = new Map<string, ImageMetadata>()
for (const [path, loader] of Object.entries(localGlob)) {
  const { default: meta } = await loader()
  localMap.set(path.replace('/public', ''), meta)
}
---

{
            {images.map((image, index) => {
              const localMeta = localMap.get(image.src)
              return (
                <div
                  class={`gallery-item ${Gallery.getSpanClass(image)} group cursor-pointer overflow-hidden rounded-3xl relative shadow-card hover:shadow-glow-strong transition-all duration-500`}
                  style={`animation: fade-in-up 0.7s ease-out ${index * 100}ms forwards; opacity: 0;`}
                >
                  {localMeta ? (
                    <Picture
                      src={localMeta}
                      alt={image.alt}
                      formats={['avif', 'webp']}
                      loading={index < 2 ? 'eager' : 'lazy'}
                      decoding={index < 2 ? 'sync' : 'async'}
                      class="w-full h-full object-cover transition-transform duration-700 ease-out"
                      style={`transform: rotate(${image.rotate}deg) scale(1.04);`}
                    />
                  ) : (
                    <Picture
                      src={image.src}
                      alt={image.alt}
                      formats={['avif', 'webp']}
                      inferSize
                      loading={index < 2 ? 'eager' : 'lazy'}
                      decoding={index < 2 ? 'sync' : 'async'}
                      class="w-full h-full object-cover transition-transform duration-700 ease-out"
                      style={`transform: rotate(${image.rotate}deg) scale(1.04);`}
                    />
                  )}
                  <div class="absolute inset-0 bg-linear-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
                </div>
              )
            })}
            {images.map((image, index) => (
              <div
                class={`${Gallery.getSpanClass(image)} group cursor-pointer overflow-hidden rounded-3xl relative shadow-card hover:shadow-glow-strong transition-all duration-500`}
                style={`animation: fade-in-up 0.7s ease-out ${index * 100}ms forwards; opacity: 0;`}
              >
                <img
                  src={image.src}
                  alt={image.alt}
                  loading={index < 2 ? 'eager' : 'lazy'}
                  decoding="async"
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out"
                  style={`transform: rotate(${image.rotate}deg) scale(1.04);`}
                />
                <div class="absolute inset-0 bg-linear-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
              </div>
            ))}
          </div>

          <!-- Botón galería completa -->
          <div class="text-center mt-12">
            <a
              href="/galeria"
              class="inline-flex items-center gap-2 px-6 py-3 bg-surface-light hover:bg-surface-hover text-foreground rounded-lg transition-colors border border-surface-border"
            >
              Ver galería completa
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  )
}

<style>
  /* Hace que el <picture> generado por Astro llene la celda del grid */
  .gallery-item :global(picture) {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Resetea la rotación orgánica en hover */
  .gallery-item:hover :global(img) {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .grid > div:hover img {
    transform: rotate(0deg) scale(1.1) !important;
  }
</style>

