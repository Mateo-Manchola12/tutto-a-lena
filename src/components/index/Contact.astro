---
import Button from '@components/ui/Button.astro'
import { BusinessInfo } from '@constants/business'

const businessInfo = await BusinessInfo.getInfo()
const { phone, email, whatsapp } = businessInfo
---

<div class="bg-surface rounded-lg p-8 shadow-elegant">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    <div class="space-y-4">
      <h3 class="text-2xl font-semibold text-foreground">¿Tienes preguntas?</h3>
      <p class="text-muted">
        Estamos aquí para ayudarte. Contáctanos por teléfono, email o WhatsApp.
      </p>
      <div class="space-y-2">
        <p class="text-foreground">
          <span class="font-semibold">Teléfono:</span>
          {phone.display}
        </p>
        <p class="text-foreground">
          <span class="font-semibold">Email:</span>
          {email.display}
        </p>
        <p class="text-foreground">
          <span class="font-semibold">WhatsApp:</span>
          {whatsapp.display}
        </p>
      </div>
    </div>
    <div class="flex flex-col gap-4 justify-center">
      <Button href={businessInfo.cta.catering} variant="primary" size="lg">
        Solicitar Catering
      </Button>
      <Button href={businessInfo.cta.contact} variant="outline" size="lg"> Contactanos </Button>
    </div>
  </div>
</div>
