---
import { BusinessInfo } from '@constants/business'
import Cloud from '@assets/cloud.svg'

const businessInfo = await BusinessInfo.getInfo()
---

<section
  class="py-16 md:py-24 bg-linear-to-r from-primary/95 to-primary via-primary/90 relative overflow-hidden border-t border-primary-hover"
>
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-10">
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_20%_50%,rgba(255,255,255,0.1)_0%,transparent_50%)]"
    >
    </div>
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_80%_80%,rgba(255,255,255,0.1)_0%,transparent_50%)]"
    >
    </div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="max-w-3xl mx-auto text-center space-y-8">
      <!-- Icon -->
      <div class="inline-block p-4 bg-white/20 rounded-full">
        <svg class="w-12 h-12 text-white" fill="currentColor" viewBox="0 0 20 20">
          <Cloud class="w-full h-full" />
        </svg>
      </div>

      <!-- Heading -->
      <div class="space-y-3">
        <h2 class="font-display text-4xl md:text-5xl font-bold text-white">
          ¿Venís a probar la diferencia?
        </h2>
        <p class="text-xl text-white/90 leading-relaxed">
          Una experiencia gastronómica que va más allá de lo que esperas. Ven y comparte con
          nosotros la magia del fuego y la tradición.
        </p>
      </div>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center pt-6">
        <a
          href={businessInfo.cta.catering}
          class="inline-flex items-center justify-center px-8 py-4 bg-white text-primary font-bold rounded-full hover:bg-gray-50 transition-colors duration-300 shadow-lg hover:shadow-glow text-lg"
        >
          Solicitar Catering
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>

        <a
          href={businessInfo.cta.contact}
          class="inline-flex items-center justify-center px-8 py-4 border-2 border-white text-white font-bold rounded-full hover:bg-white/10 transition-colors duration-300 text-lg"
        >
          Contáctanos
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path>
          </svg>
        </a>
      </div>

      <!-- Highlight -->
      <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-xl p-6 mt-8">
        <p class="text-white/95 text-lg">
          <span class="font-bold">🍕 Horarios:</span> Martes a Domingo de 12:00 a 23:00 hs.
        </p>
        <p class="text-white/90 text-sm mt-2">
          Abierto todos los días excepto lunes. Reservas recomendadas para grupos.
        </p>
      </div>
    </div>
  </div>
</section>
