---
import Button from '@components/ui/Button.astro'
---

<section
  class="relative h-[70vh] md:h-[80vh] flex items-center justify-center bg-cover bg-center"
  style="background-image: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.5)), url('/images/hero-food-truck.jpg');"
>
  <div class="container mx-auto px-4 text-center text-white">
    <h1 class="font-display text-4xl md:text-6xl lg:text-7xl font-bold mb-4">Tutto a Leña</h1>
    <p class="text-xl md:text-2xl mb-8 text-neutral-100">Arte italiano, corazón argentino</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button href="/carta" variant="primary" size="lg"> Ver carta </Button>
      <Button href="/reservar" variant="secondary" size="lg"> Reservar mesa </Button>
    </div>
  </div>
</section>
