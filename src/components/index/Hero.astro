---
import Button from '@components/ui/Button.astro'
import logo from '@assets/logo.png'
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0">
    <img
      src="/images/hero-food-truck.jpg"
      alt="Tutto a Leña Food Truck"
      class="w-2/3 h-full object-cover ml-auto opacity-80"
      style="transform: scaleX(-1);"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-surface via-surface/80 to-surface/30"></div>
  </div>

  <!-- Content -->
  <div class="container mx-auto px-4 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left Column - Text & Logo -->
      <div class="space-y-8">
        <img
          src={logo.src}
          alt="Tutto a Leña"
          class="h-32 md:h-40 w-auto"
          width={logo.width}
          height={logo.height}
        />
        <h1 class="font-display text-5xl md:text-7xl font-bold leading-tight text-foreground">
          Sabor auténtico
          <br />
          <span class="text-primary">al fuego</span>
        </h1>
        <p class="font-handwriting text-2xl md:text-3xl text-primary">
          Arte italiano, corazón argentino
        </p>
        <p class="text-lg md:text-xl text-muted max-w-lg">
          Pizzas napolitanas al horno de leña, empanadas artesanales y cerveza tirada. Si tiene
          horno a leña, tiene magia.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <Button href="/carta" variant="primary" size="lg">
            Ver Carta
            <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </Button>
          <Button href="/donde-estamos" variant="outline" size="lg"> Dónde Estamos </Button>
        </div>
      </div>

      <!-- Right Column - Image space (covered by background) -->
      <div class="hidden lg:block"></div>
    </div>
  </div>
</section>
