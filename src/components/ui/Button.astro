---
interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost'
  size?: 'sm' | 'md' | 'lg'
  href?: string
  type?: 'button' | 'submit' | 'reset'
  ariaLabel?: string
  disabled?: boolean
  class?: string
}
const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  ariaLabel,
  disabled = false,
  class: className,
} = Astro.props as Props

const sizes = {
  sm: 'h-9 px-3 text-sm',
  md: 'h-10 px-4 text-base',
  lg: 'h-12 px-6 text-lg',
}[size]

const variants = {
  primary:
    'bg-primary text-primary-foreground hover:bg-primary-hover active:bg-primary-active shadow-glow hover:shadow-glow-strong',
  secondary:
    'bg-surface text-foreground hover:bg-surface-hover border border-surface-border hover:border-primary',
  outline:
    'border-2 border-primary bg-transparent hover:bg-primary text-primary hover:text-primary-foreground',
  ghost: 'bg-transparent hover:bg-surface-hover text-foreground hover:text-primary',
}[variant]

const base = `inline-flex items-center justify-center rounded-md transition-[background,color,transform] duration-[var(--transition-base)] disabled:opacity-60 disabled:cursor-not-allowed ${sizes} ${variants} ${className ?? ''}`
---

{
  href ? (
    <a class={base} href={href} aria-label={ariaLabel}>
      <slot />
    </a>
  ) : (
    <button class={base} type={type} aria-label={ariaLabel} disabled={disabled}>
      <slot />
    </button>
  )
}
