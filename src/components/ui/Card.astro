---
interface Props {
  title?: string
  subtitle?: string
  imageSrc?: string
  imageAlt?: string
  class?: string
}
const { title, subtitle, imageSrc, imageAlt, class: className } = Astro.props as Props
---

<article
  class={`rounded-lg bg-surface shadow-elegant border border-surface-border overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-2xl animate-fade-in-up animate-duration-700 animate-once ${className ?? ''}`}
>
  {
    imageSrc && (
      <img
        src={imageSrc}
        alt={imageAlt ?? ''}
        class="w-full h-48 object-cover"
        loading="lazy"
        decoding="async"
      />
    )
  }
  <div class="p-4">
    {title && <h3 class="font-semibold text-lg text-foreground">{title}</h3>}
    {subtitle && <p class="text-sm text-muted mt-1">{subtitle}</p>}
    <div class="mt-4">
      <slot />
    </div>
  </div>
</article>
