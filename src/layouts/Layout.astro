---
import '@styles/global.css'

// Inter - pesos: 400, 500, 600, 700
import '@fontsource/inter/400.css'
import '@fontsource/inter/500.css'
import '@fontsource/inter/600.css'
import '@fontsource/inter/700.css'

// Playfair Display - pesos: 700, 900
import '@fontsource/playfair-display/700.css'
import '@fontsource/playfair-display/900.css'

// Caveat - peso: 700
import '@fontsource/caveat/700.css'

import Footer from '@/components/layout/Footer.astro'
import Header from '@/components/layout/Header.astro'
import MetaTags from '@/components/layout/MetaTags.astro'
import { ClientRouter } from 'astro:transitions'
import type { Props as MetaTagsProps } from '@/components/layout/MetaTags.astro'
import { SITE_MAP, NO_INDEX_ROUTES } from '@/constants/site_map'

type Props = {
  title?: string
  seo?: MetaTagsProps
}

const { title, seo = {} } = Astro.props
const defaultTitle = 'Tutto a Leña | Arte italiano, corazón argentino'
const currentSlug = Astro.url.pathname.replace(/^\//, '').replace(/\/$/, '')
const currentPage = SITE_MAP.find(page => page.slug === currentSlug)

const defaultKeywordsBySlug: Record<string, string[]> = {
  '': ['pizza artesanal', 'horno a lena', 'cocina italiana', 'restaurante en buenos aires'],
  carta: ['menu italiano', 'pizzas a lena', 'pastas frescas', 'entradas y postres'],
  'donde-estamos': ['ubicacion restaurante', 'horarios tutto a lena', 'como llegar'],
  catering: ['catering italiano', 'catering para eventos', 'pizza party'],
  eventos: ['eventos gastronomicos', 'eventos privados', 'catas y experiencias'],
  galeria: ['fotos restaurante', 'galeria de platos', 'horno a lena'],
  contacto: ['telefono tutto a lena', 'whatsapp restaurante', 'reservas por contacto'],
  blog: ['blog de cocina italiana', 'recetas italianas', 'novedades gastronomicas'],
  reservar: ['reservar mesa', 'reserva restaurante', 'disponibilidad'],
  'politica-privacidad': ['politica de privacidad'],
  'terminos-condiciones': ['terminos y condiciones'],
}

const computedKeywords = seo.keywords || defaultKeywordsBySlug[currentSlug] || []

const computedTitle =
  seo.title ||
  (currentPage
    ? `Tutto a Leña | ${currentPage.name}`
    : title
      ? `${title} | Tutto a Leña`
      : defaultTitle)
const computedDescription = seo.description || currentPage?.description
const computedNoIndex = seo.noindex ?? NO_INDEX_ROUTES.includes(currentSlug)
---

<!doctype html>
<html lang="es" transition:name="root" transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <MetaTags
      title={computedTitle}
      description={computedDescription}
      keywords={computedKeywords}
      noindex={computedNoIndex}
      {...seo}
    />
    <title>{computedTitle}</title>
    <ClientRouter />
  </head>
  <body class="grid min-h-dvh grid-rows-[auto_1fr_auto]">
    <header class="sticky top-0 z-50">
      <Header />
    </header>
    <main transition:animate="slide">
      <slot />
    </main>
    <footer class="bg-surface"><Footer /></footer>
  </body>
</html>
