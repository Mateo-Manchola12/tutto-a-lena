---
import '@styles/global.css'
import interLatinVariableUrl from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url'
import playfairLatin700Url from '@fontsource/playfair-display/files/playfair-display-latin-700-normal.woff2?url'
import caveatLatin700Url from '@fontsource/caveat/files/caveat-latin-700-normal.woff2?url'

import Footer from '@/components/layout/Footer.astro'
import Header from '@/components/layout/Header.astro'
import MetaTags from '@/components/layout/MetaTags.astro'
import { ClientRouter } from 'astro:transitions'
import type { Props as MetaTagsProps } from '@/components/layout/MetaTags.astro'
import { SITE_MAP, NO_INDEX_ROUTES } from '@/constants/site_map'

type Props = {
  title?: string
  seo?: MetaTagsProps
}

const { title, seo = {} } = Astro.props
const defaultTitle = 'Tutto a Leña | Arte italiano, corazón argentino'
const currentSlug = Astro.url.pathname.replace(/^\//, '').replace(/\/$/, '')
const currentPage = SITE_MAP.find(page => page.slug === currentSlug)

const defaultKeywordsBySlug: Record<string, string[]> = {
  '': ['pizza artesanal', 'horno a lena', 'cocina italiana', 'restaurante en buenos aires'],
  carta: ['menu italiano', 'pizzas a lena', 'pastas frescas', 'entradas y postres'],
  'donde-estamos': ['ubicacion restaurante', 'horarios tutto a lena', 'como llegar'],
  catering: ['catering italiano', 'catering para eventos', 'pizza party'],
  eventos: ['eventos gastronomicos', 'eventos privados', 'catas y experiencias'],
  galeria: ['fotos restaurante', 'galeria de platos', 'horno a lena'],
  contacto: ['telefono tutto a lena', 'whatsapp restaurante', 'reservas por contacto'],
  blog: ['blog de cocina italiana', 'recetas italianas', 'novedades gastronomicas'],
  reservar: ['reservar mesa', 'reserva restaurante', 'disponibilidad'],
  'politica-privacidad': ['politica de privacidad'],
  'terminos-condiciones': ['terminos y condiciones'],
}

const computedKeywords = seo.keywords || defaultKeywordsBySlug[currentSlug] || []

const computedTitle =
  seo.title ||
  (currentPage
    ? `Tutto a Leña | ${currentPage.name}`
    : title
      ? `${title} | Tutto a Leña`
      : defaultTitle)
const computedDescription = seo.description || currentPage?.description
const computedNoIndex = seo.noindex ?? NO_INDEX_ROUTES.includes(currentSlug)
---

<!doctype html>
<html lang="es" transition:name="root" transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="preload" href={interLatinVariableUrl} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={playfairLatin700Url} as="font" type="font/woff2" crossorigin />
    <style is:global define:vars={{ interLatinVariableUrl, playfairLatin700Url, caveatLatin700Url }}
    >
      @font-face {
        font-family: 'Inter Variable';
        font-style: normal;
        font-display: swap;
        font-weight: 100 900;
        src: url(var(--interLatinVariableUrl)) format('woff2-variations');
        unicode-range:
          U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308,
          U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
      }

      @font-face {
        font-family: 'Playfair Display';
        font-style: normal;
        font-display: swap;
        font-weight: 700;
        src: url(var(--playfairLatin700Url)) format('woff2');
        unicode-range:
          U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F,
          U+20AC, U+2122, U+FEFF, U+FFFD;
      }

      @font-face {
        font-family: 'Caveat';
        font-style: normal;
        font-display: optional;
        font-weight: 700;
        src: url(var(--caveatLatin700Url)) format('woff2');
        unicode-range:
          U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+2000-206F,
          U+20AC, U+2122, U+FEFF, U+FFFD;
      }
    </style>
    <MetaTags
      title={computedTitle}
      description={computedDescription}
      keywords={computedKeywords}
      noindex={computedNoIndex}
      {...seo}
    />
    <title>{computedTitle}</title>
    <ClientRouter />
  </head>
  <body class="grid min-h-dvh grid-rows-[auto_1fr_auto]">
    <header class="sticky top-0 z-50">
      <Header />
    </header>
    <main transition:animate="fade">
      <slot />
    </main>
    <footer class="bg-surface"><Footer /></footer>
  </body>
</html>
