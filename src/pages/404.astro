---
import Layout from '@/layouts/Layout.astro'
import Schema from '@/components/layout/Schema.astro'
import Button from '@/components/ui/Button.astro'
import { MAIN_ROUTES } from '@/constants/site_map'
import { BusinessInfo } from '@/constants/business'

const businessInfo = await BusinessInfo.getInfo()

const title = 'Página no encontrada'
---

<Layout title={title}>
  <Schema type="organization" />

  <main class="min-h-[70vh] flex items-center justify-center px-4">
    <div class="max-w-xl mx-auto text-center py-12">
      <!-- Error Code -->
      <div class="mb-8">
        <h1 class="text-9xl font-bold text-primary mb-4">404</h1>
        <div class="h-1 w-24 bg-primary mx-auto mb-8"></div>
      </div>

      <!-- Title -->
      <h2 class="text-4xl md:text-5xl font-display font-bold text-foreground mb-4">
        Oups, página no encontrada
      </h2>

      <!-- Description -->
      <p class="text-lg text-muted mb-8">
        Lo sentimos, la página que buscas no existe. Pero no te preocupes, puedes volver a nuestro
        sitio principal o explorar las secciones que tenemos para ti.
      </p>

      <!-- CTA Button -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <Button href={businessInfo.cta.home} variant="primary" size="lg" class="font-semibold">
          Volver al inicio
        </Button>
        <Button href={businessInfo.cta.contact} variant="outline" size="lg" class="font-semibold">
          Contactanos
        </Button>
      </div>

      <!-- Navigation Links -->
      <div class="bg-surface rounded-lg p-8 border border-surface-border">
        <h3 class="text-lg font-semibold text-foreground mb-6">Quizás busques:</h3>
        <nav class="grid grid-cols-2 gap-4 md:grid-cols-3">
          {
            MAIN_ROUTES.map(route => (
              <a
                href={`/${route.slug}`}
                class="text-muted-foreground hover:text-primary font-medium transition-colors text-sm"
              >
                {route.name}
              </a>
            ))
          }
        </nav>
      </div>

      <!-- Help Text -->
      <p class="text-sm text-muted mt-8">
        Si crees que esto es un error, por favor{' '}
        <a href={businessInfo.cta.contact} class="text-primary hover:underline font-semibold">
          contáctanos
        </a>
      </p>
    </div>
  </main>

  <!-- Suggestions Section -->
  <section class="py-12 bg-surface-light border-t border-surface-border">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-display font-bold text-foreground mb-4">Explora Tutto a Leña</h2>
        <p class="text-muted">Descubre lo que podemos ofrecerte</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <a
          href={businessInfo.cta.menu}
          class="group bg-surface p-6 rounded-lg border border-surface-border hover:border-primary hover:shadow-glow transition-all"
        >
          <div class="mb-4 text-4xl">🍕</div>
          <h3 class="font-bold text-foreground mb-2 group-hover:text-primary transition-colors">
            Nuestro Menú
          </h3>
          <p class="text-muted text-sm">
            Descubre nuestras pizzas a leña y deliciosos platos italianos
          </p>
        </a>

        <a
          href={businessInfo.cta.location}
          class="group bg-surface p-6 rounded-lg border border-surface-border hover:border-primary hover:shadow-glow transition-all"
        >
          <div class="mb-4 text-4xl">📍</div>
          <h3 class="font-bold text-foreground mb-2 group-hover:text-primary transition-colors">
            Dónde Estamos
          </h3>
          <p class="text-muted text-sm">Encuentra nuestra ubicación, horarios y cómo llegar</p>
        </a>

        <a
          href={businessInfo.cta.contact}
          class="group bg-surface p-6 rounded-lg border border-surface-border hover:border-primary hover:shadow-glow transition-all"
        >
          <div class="mb-4 text-4xl">📞</div>
          <h3 class="font-bold text-foreground mb-2 group-hover:text-primary transition-colors">
            Contactanos
          </h3>
          <p class="text-muted text-sm">Ponte en contacto con nosotros para reservas o consultas</p>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  h1 {
    letter-spacing: -0.02em;
  }
</style>
