---
import Layout from '@/layouts/Layout.astro'
import MetaTags from '@components/layout/MetaTags.astro'
import Breadcrumbs from '@components/layout/Breadcrumbs.astro'
import Container from '@components/layout/Container.astro'
import Section from '@components/layout/Section.astro'
import { SITE_MAP } from '@constants/site_map'

const page = SITE_MAP.find(p => p.slug === 'reservar')!
---

<Layout>
  <MetaTags
    title={`Tutto a Leña | ${page.name}`}
    description={page.description}
    canonical={page.path}
  />
  <Container>
    <Breadcrumbs
      items={[
        { label: 'Inicio', href: '/' },
        { label: 'Reservar', href: '/reservar' },
      ]}
    />
    <Section title="Reservar mesa" subtitle="Próximamente: sistema de reservas online">
      <p class="text-muted">
        Por ahora, realiza tu reserva llamando al teléfono en la página de Contacto.
      </p>
    </Section>
  </Container>
</Layout>
