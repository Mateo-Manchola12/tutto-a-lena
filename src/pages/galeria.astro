---
import { Picture } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import Layout from '../layouts/Layout.astro'
import Schema from '@components/layout/Schema.astro'
import Container from '@components/layout/Container.astro'
import Section from '@components/layout/Section.astro'
import { Gallery } from '@/constants/gallery'

const images = await Gallery.getAllSorted()

// Mapa de imágenes locales (public/images/) → ImageMetadata para optimización
const localGlob = import.meta.glob<{ default: ImageMetadata }>(
  '/public/images/**/*.{jpg,jpeg,png,webp,avif}',
)
const localMap = new Map<string, ImageMetadata>()
for (const [path, loader] of Object.entries(localGlob)) {
  const { default: meta } = await loader()
  localMap.set(path.replace('/public', ''), meta)
}
---

<Layout>
  <Schema type="aggregate" />

  <Container>
    <Section title="Galería" subtitle="Un vistazo a nuestros platos, horno y espacio">
      <div class="w-full">
        {images.length === 0 ? (
          <div class="flex flex-col items-center justify-center gap-4 py-24 text-center">
            <svg class="w-16 h-16 text-muted-foreground/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <p class="text-muted-foreground text-lg">Galería próximamente</p>
            <p class="text-muted-foreground/60 text-sm max-w-sm">
              Estamos preparando contenido. Vuelve pronto para descubrir nuestros momentos.
            </p>
          </div>
        ) : (
          <div
            id="gallery-grid"
            class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 auto-rows-[250px] gap-4 md:gap-6"
          >
            {images.map((image, index) => {
              const localMeta = localMap.get(image.src)
              return (
                <div
                  class={`gallery-item ${Gallery.getSpanClass(image)} group cursor-pointer overflow-hidden rounded-2xl relative shadow-md hover:shadow-xl transition-all duration-300 transform hover:scale-[1.02]`}
                  style={`animation: fade-in-up 0.6s ease-out ${Math.min(index, 10) * 50}ms forwards; opacity: 0;`}
                >
                  {localMeta ? (
                    <Picture
                      src={localMeta}
                      alt={image.alt}
                      formats={['avif', 'webp']}
                      loading={index < 4 ? 'eager' : 'lazy'}
                      decoding={index < 4 ? 'sync' : 'async'}
                      class="w-full h-full object-cover transition-transform duration-700 ease-out"
                      style={`transform: rotate(${image.rotate}deg) scale(1.04);`}
                    />
                  ) : (
                    <Picture
                      src={image.src}
                      alt={image.alt}
                      formats={['avif', 'webp']}
                      inferSize
                      loading={index < 4 ? 'eager' : 'lazy'}
                      decoding={index < 4 ? 'sync' : 'async'}
                      class="w-full h-full object-cover transition-transform duration-700 ease-out"
                      style={`transform: rotate(${image.rotate}deg) scale(1.04);`}
                    />
                  )}
                  <!-- Overlay gradient -->
                  <div class="absolute inset-0 bg-linear-to-t from-black/60 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
                  <!-- Description on hover -->
                  {image.description && (
                    <div class="absolute bottom-0 left-0 right-0 p-4 text-white transform translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out">
                      <p class="text-sm font-medium drop-shadow-lg">{image.description}</p>
                    </div>
                  )}
                </div>
              )
            })}
          </div>
        )}
      </div>
    </Section>
  </Container>
</Layout>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Hace que el <picture> generado por Astro llene la celda del grid */
  .gallery-item :global(picture) {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Resetea la rotación orgánica en hover */
  .gallery-item:hover :global(img) {
    transform: rotate(0deg) scale(1.1) !important;
  }
</style>

