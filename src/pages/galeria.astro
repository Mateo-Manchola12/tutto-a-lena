---
import Layout from '../layouts/Layout.astro'
import Schema from '@components/layout/Schema.astro'
import Container from '@components/layout/Container.astro'
import Section from '@components/layout/Section.astro'
import { Gallery } from '@/constants/gallery'
import { Picture } from 'astro:assets'

// ─── Datos desde Firestore ────────────────────────────────────────────────────
const images = await Gallery.getAllSorted()

---

<Layout>
  <Schema type="aggregate" />

  <Container>
    <Section title="Galería" subtitle="Un vistazo a nuestros platos, horno y espacio">
      <div class="w-full">
        <div
          id="gallery-grid"
          class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 auto-rows-[250px] gap-4 md:gap-6"
        >
          {images.map((image, index) => {
            const spanClass = Gallery.getSpanClass(image)
            return (
              <div
                class={`gallery-item ${spanClass} group cursor-pointer overflow-hidden rounded-2xl relative shadow-md hover:shadow-xl transition-all duration-300`}
                style={`animation: fade-in-up 0.6s ease-out ${Math.min(index, 10) * 50}ms forwards; opacity: 0;`}
              >
                <Picture
                  src={image.src}
                  alt={image.alt}
                  formats={['avif', 'webp']}
                  inferSize
                  sizes="(max-width: 639px) 50vw, (max-width: 767px) 33vw, 25vw"
                  loading={index < 2 ? 'eager' : 'lazy'}
                  decoding={index < 2 ? 'sync' : 'async'}
                  class="w-full h-full object-cover transition-transform duration-700 ease-out"
                  style={`transform: rotate(${image.rotate}deg) scale(1.04);`}
                />
                <!-- Overlay gradient -->
                <div class="absolute inset-0 bg-linear-to-t from-black/60 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />
                <!-- Descripción en hover -->
                {image.description && (
                  <div class="absolute bottom-0 left-0 right-0 p-4 text-white transform translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out">
                    <p class="text-sm font-medium drop-shadow-lg">{image.description}</p>
                  </div>
                )}
              </div>
            )
          })}
        </div>
      </div>
    </Section>
  </Container>
</Layout>

<style>
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* El elemento <picture> generado por Astro debe llenar la celda del grid */
  .gallery-item {
    content-visibility: auto;
    contain-intrinsic-size: 250px 250px;
  }

  .gallery-item :global(picture) {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* Resetea la rotación orgánica en hover */
  .gallery-item:hover :global(img) {
    transform: rotate(0deg) scale(1.1) !important;
  }
</style>

<!-- Safelist Tailwind — evita purge de clases de span dinámicas -->
