---
import Layout from '@/layouts/Layout.astro'
import MetaTags from '@components/layout/MetaTags.astro'
import Breadcrumbs from '@components/layout/Breadcrumbs.astro'
import Container from '@components/layout/Container.astro'
import Section from '@components/layout/Section.astro'
import { SITE_MAP } from '@constants/site_map'
import { BUSINESS_INFO } from '@constants/business'

const page = SITE_MAP.find(p => p.slug === 'donde-estamos')!
const { address, coordinates, phone, email, hours } = BUSINESS_INFO
---

<Layout>
  <MetaTags
    title={`Tutto a Leña | ${page.name}`}
    description={page.description}
    canonical={page.path}
  />
  <Breadcrumbs
    items={[
      { label: 'Inicio', href: '/' },
      { label: 'Dónde estamos', href: '/donde-estamos' },
    ]}
  />

  <!-- Hero Section -->
  <section
    class="py-12 md:py-16 bg-gradient-to-b from-primary/10 to-background border-b border-surface-border"
  >
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center space-y-4">
        <h1 class="font-display text-5xl md:text-6xl font-bold text-foreground">
          ¿Dónde <span class="text-primary">nos encontramos?</span>
        </h1>
        <p class="text-xl text-muted max-w-2xl mx-auto">
          Visítanos en nuestro espacio en Buenos Aires. Te esperamos con las mejores pizzas a leña
        </p>
      </div>
    </div>
  </section>

  <Container>
    <!-- Ubicación e Info -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 py-12 md:py-16">
      <!-- Info Column -->
      <div class="lg:col-span-1 space-y-8">
        <!-- Dirección -->
        <div
          class="bg-surface rounded-2xl border border-surface-border p-6 hover:border-primary hover:shadow-glow transition-all duration-300"
        >
          <div class="flex items-start gap-4">
            <div class="text-3xl flex-shrink-0">📍</div>
            <div>
              <h3 class="text-lg font-bold text-foreground mb-2">Dirección</h3>
              <p class="text-muted-foreground leading-relaxed">
                {address?.street ?? '—'}<br />
                {address?.city ?? ''}, {address?.postalCode ?? ''}
              </p>
              <p class="text-sm text-muted mt-2">{address?.country ?? ''}</p>
            </div>
          </div>
        </div>

        <!-- Teléfono -->
        <div
          class="bg-surface rounded-2xl border border-surface-border p-6 hover:border-primary hover:shadow-glow transition-all duration-300"
        >
          <div class="flex items-start gap-4">
            <div class="text-3xl flex-shrink-0">📞</div>
            <div>
              <h3 class="text-lg font-bold text-foreground mb-2">Teléfono</h3>
              <a href={`tel:${phone}`} class="text-primary font-semibold hover:underline">
                {phone ?? '—'}
              </a>
              <p class="text-sm text-muted mt-1">Llamadas y WhatsApp</p>
            </div>
          </div>
        </div>

        <!-- Email -->
        <div
          class="bg-surface rounded-2xl border border-surface-border p-6 hover:border-primary hover:shadow-glow transition-all duration-300"
        >
          <div class="flex items-start gap-4">
            <div class="text-3xl flex-shrink-0">✉️</div>
            <div>
              <h3 class="text-lg font-bold text-foreground mb-2">Email</h3>
              <a
                href={`mailto:${email}`}
                class="text-primary font-semibold hover:underline break-all"
              >
                {email ?? '—'}
              </a>
              <p class="text-sm text-muted mt-1">Respuesta en 24hs</p>
            </div>
          </div>
        </div>

        <!-- Horarios -->
        <div
          class="bg-gradient-to-br from-primary/10 to-primary/5 rounded-2xl border border-primary/20 p-6"
        >
          <div class="flex items-start gap-4">
            <div class="text-3xl flex-shrink-0">🕐</div>
            <div>
              <h3 class="text-lg font-bold text-foreground mb-3">Horarios</h3>
              <ul class="space-y-2">
                {
                  (Array.isArray(hours) ? hours : []).map(h => (
                    <li class="flex justify-between gap-4 text-muted-foreground">
                      <span class="font-semibold">{h.day}:</span>
                      <span>
                        {h.open} - {h.close}
                      </span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>
      </div>

      <!-- Mapa -->
      <div class="lg:col-span-2">
        <div
          class="bg-surface rounded-2xl border border-surface-border overflow-hidden shadow-elegant h-full min-h-[400px] md:min-h-[600px]"
        >
          <iframe
            class="w-full h-full"
            loading="lazy"
            src={`https://www.google.com/maps?q=${coordinates?.lat ?? 0},${coordinates?.lng ?? 0}&output=embed`}
            title="Ubicación Tutto a Leña"></iframe>
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <section
      class="py-12 bg-gradient-to-r from-primary/10 to-primary/5 rounded-2xl border border-primary/20 text-center space-y-6 mb-12"
    >
      <h3 class="font-display text-3xl md:text-4xl font-bold text-foreground">
        ¿Querés que vayamos a tu evento?
      </h3>
      <p class="text-lg text-muted max-w-2xl mx-auto">
        También ofrecemos servicio de catering. Llevamos el horno a leña y toda la magia de Tutto a
        Leña donde vos estés.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/catering"
          class="inline-flex items-center justify-center px-8 py-3 bg-primary text-primary-foreground font-bold rounded-full hover:bg-primary-hover transition-colors shadow-glow"
        >
          Conocer Catering
        </a>
        <a
          href="/contacto"
          class="inline-flex items-center justify-center px-8 py-3 border-2 border-primary text-primary font-bold rounded-full hover:bg-primary/10 transition-colors"
        >
          Consultanos
        </a>
      </div>
    </section>
  </Container>
</Layout>
