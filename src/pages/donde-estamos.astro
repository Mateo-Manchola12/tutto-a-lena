---
import Layout from '@/layouts/Layout.astro'
import Breadcrumbs from '@components/layout/Breadcrumbs.astro'
import Container from '@components/layout/Container.astro'
import { BusinessInfo } from '@constants/business'
import { getCurrentEvent, formatEventDate, getUpcomingEvents } from '@constants/events'
import Button from '@/components/ui/Button.astro'
import { sortBusinessHours } from '@/lib/sort-hours'

const businessInfo = await BusinessInfo.getInfo()
const { phone, email, hours } = businessInfo
const orderedHours = sortBusinessHours(hours)
const currentEvent = await getCurrentEvent()
const upcomingEvents = await getUpcomingEvents()
---

<Layout>
  <Breadcrumbs
    items={[
      { label: 'Inicio', href: '/' },
      { label: 'Dónde estamos', href: '/donde-estamos' },
    ]}
  />

  <!-- Hero Section -->
  <section
    class="py-12 md:py-16 bg-linear-to-b from-primary/10 to-background border-b border-surface-border"
  >
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center space-y-4">
        <h1 class="font-display text-5xl md:text-6xl font-bold text-foreground">
          ¿Dónde <span class="text-primary">nos encontramos?</span>
        </h1>
        <p class="text-xl text-muted max-w-2xl mx-auto">
          Visítanos. Te esperamos con las mejores pizzas a leña
        </p>
      </div>
    </div>
  </section>

  <Container>
    <!-- Ubicación e Info -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 py-12 md:py-16">
      <!-- Info Column -->
      <div class="lg:col-span-1 space-y-8">
        <!-- Teléfono -->
        <div
          class="bg-surface rounded-2xl border border-surface-border p-6 hover:border-primary hover:shadow-glow transition-all duration-300"
        >
          <div class="flex items-start gap-4">
            <div class="text-3xl shrink-0">📞</div>
            <div>
              <h3 class="text-lg font-bold text-foreground mb-2">Teléfono</h3>
              <a href={phone.href} class="text-primary font-semibold hover:underline">
                {phone.display}
              </a>
              <p class="text-sm text-muted mt-1">Llamadas y WhatsApp</p>
            </div>
          </div>
        </div>

        <!-- Email -->
        <div
          class="bg-surface rounded-2xl border border-surface-border p-6 hover:border-primary hover:shadow-glow transition-all duration-300"
        >
          <div class="flex items-start gap-4">
            <div class="text-3xl shrink-0">✉️</div>
            <div>
              <h3 class="text-lg font-bold text-foreground mb-2">Email</h3>
              <a href={email.href} class="text-primary font-semibold hover:underline break-all">
                {email.display}
              </a>
              <p class="text-sm text-muted mt-1">Respuesta en 24hs</p>
            </div>
          </div>
        </div>

        <!-- Horarios -->
        <div
          class="bg-linear-to-br from-primary/10 to-primary/5 rounded-2xl border border-primary/20 p-6"
        >
          <div class="flex items-start gap-4">
            <div class="text-3xl shrink-0">🕐</div>
            <div>
              <h3 class="text-lg font-bold text-foreground mb-3">Horarios</h3>
              <ul class="space-y-2">
                {
                  orderedHours.map(([day, h]) => (
                    <li class="flex justify-between gap-4 text-muted-foreground">
                      <span class="font-semibold">{day}:</span>
                      <span>
                        {h.open} - {h.close}
                      </span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </div>
      </div>

      <!-- Mapa -->
      <div class="lg:col-span-2">
        {currentEvent ? (
          <div class="bg-surface rounded-2xl border border-surface-border overflow-hidden shadow-elegant h-full min-h-[400px] md:min-h-[600px] p-8 flex flex-col justify-center">
            <div class="space-y-6">
              <div>
                <h3 class="text-2xl font-bold text-foreground mb-2">🎉 {currentEvent.title}</h3>
                <p class="text-primary font-semibold mb-4">
                  📅 Hoy {formatEventDate(currentEvent.date)}
                </p>
              </div>

              <div class="space-y-4">
                <div>
                  <h4 class="font-bold text-foreground mb-2">Descripción</h4>
                  <p class="text-muted">{currentEvent.description}</p>
                </div>

                <div>
                  <h4 class="font-bold text-foreground mb-2">⏰ Horario</h4>
                  <p class="text-muted">
                    {currentEvent.startTime}
                    {currentEvent.endTime ? ` - ${currentEvent.endTime}` : ''}
                  </p>
                </div>

                {currentEvent.location && (
                  <div>
                    <h4 class="font-bold text-foreground mb-2">📍 Ubicación</h4>
                    <p class="text-muted">{currentEvent.location}</p>
                  </div>
                )}
              </div>

              {currentEvent.cta && (
                <Button href={currentEvent.cta.url} variant="primary" class="w-full">
                  {currentEvent.cta.label}
                </Button>
              )}
            </div>
          </div>
        ) : (
          <div class="bg-linear-to-br from-primary/10 to-primary/5 rounded-2xl border border-primary/20 overflow-hidden shadow-elegant h-full min-h-[400px] md:min-h-[600px] p-8 flex flex-col justify-center items-center text-center">
            <div class="space-y-6">
              <div class="text-6xl">🎭</div>
              <div>
                <h3 class="text-2xl font-bold text-foreground mb-3">
                  No tenemos eventos ahora mismo
                </h3>
                <p class="text-muted max-w-sm mx-auto">
                  Pero pronto te sorprenderemos con experiencias culinarias únicas. Descubre nuestros
                  próximos eventos o contáctanos para participar.
                </p>
              </div>

              <div class="flex flex-col sm:flex-row gap-3 justify-center pt-4">
                {upcomingEvents.length > 0 ? (
                  <>
                    <Button
                      href="/eventos"
                      variant="primary"
                      class="px-6 py-2 font-bold h-auto"
                    >
                      Ver Próximos Eventos
                    </Button>
                    <Button
                      href={businessInfo.cta.contact}
                      variant="outline"
                      class="px-6 py-2 font-bold h-auto"
                    >
                      Contáctanos
                    </Button>
                  </>
                ) : (
                  <Button
                    href={businessInfo.cta.contact}
                    variant="primary"
                    class="px-6 py-2 font-bold h-auto"
                  >
                    Contáctanos
                  </Button>
                )}
              </div>
            </div>
          </div>
        )}
      </div>
    </div>
    <!-- CTA Section -->
    <section
      class="py-12 px-6 bg-linear-to-r from-primary/10 to-primary/5 rounded-2xl border border-primary/20 text-center space-y-6 mb-12"
    >
      <h3 class="font-display text-3xl md:text-4xl font-bold text-foreground">
        ¿Querés que vayamos a tu evento?
      </h3>
      <p class="text-lg text-muted max-w-2xl mx-auto">
        También ofrecemos servicio de catering. Llevamos el horno a leña y toda la magia de Tutto a
        Leña donde vos estés.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button
          href={businessInfo.cta.catering}
          variant="primary"
          class="px-8 py-3 font-bold h-auto"
        >
          Conocer Catering
        </Button>
        <Button
          href={businessInfo.cta.contact}
          variant="outline"
          class="px-8 py-3 font-bold h-auto"
        >
          Consultanos
        </Button>
      </div>
    </section>
  </Container>
</Layout>
