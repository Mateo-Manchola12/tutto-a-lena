---
import Layout from '@/layouts/Layout.astro'
import MetaTags from '@components/layout/MetaTags.astro'
import Breadcrumbs from '@components/layout/Breadcrumbs.astro'
import Container from '@components/layout/Container.astro'
import Section from '@components/layout/Section.astro'
import { SITE_MAP } from '@constants/site_map'
import { BUSINESS_INFO } from '@constants/business'

const page = SITE_MAP.find(p => p.slug === 'donde-estamos')!
const { address, coordinates, phone, email, hours } = BUSINESS_INFO
---

<Layout>
  <MetaTags
    title={`Tutto a Leña | ${page.name}`}
    description={page.description}
    canonical={page.path}
  />
  <Container>
    <Breadcrumbs
      items={[
        { label: 'Inicio', href: '/' },
        { label: 'Dónde estamos', href: '/donde-estamos' },
      ]}
    />
    <Section title="¿Dónde estamos?" subtitle="Ubicación y horarios">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <h3 class="font-semibold">Dirección</h3>
          <p class="text-muted">{address.street}, {address.city}</p>
          <p class="text-muted">{address.postalCode}, {address.country}</p>
          <h3 class="font-semibold mt-4">Contacto</h3>
          <p class="text-muted">Tel: {phone}</p>
          <p class="text-muted">Email: {email}</p>
          <h3 class="font-semibold mt-4">Horarios</h3>
          <ul class="text-muted">
            {
              hours.map(h => (
                <li>
                  {h.day}: {h.open} - {h.close}
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <iframe
            class="w-full h-80 rounded-md border"
            loading="lazy"
            src={`https://www.google.com/maps?q=${coordinates.lat},${coordinates.lng}&output=embed`}
            title="Mapa Tutto a Leña"></iframe>
        </div>
      </div>
    </Section>
  </Container>
</Layout>
