---
import Layout from '@/layouts/Layout.astro'
import MetaTags from '@components/layout/MetaTags.astro'
import Container from '@components/layout/Container.astro'
import Section from '@components/layout/Section.astro'
import { SITE_MAP } from '@constants/site_map'

const page = SITE_MAP.find(p => p.slug === 'terminos-condiciones')!
---

<Layout>
  <MetaTags
    title={`Tutto a Leña | ${page.name}`}
    description={page.description}
    canonical={page.path}
    noindex={true}
  />
  <Container>
    <Section title="Términos y Condiciones" subtitle="Actualizaremos esta sección próximamente">
      <p class="text-muted">Condiciones de uso del sitio y términos del servicio.</p>
    </Section>
  </Container>
</Layout>
