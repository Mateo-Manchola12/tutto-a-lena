---
import Layout from '@/layouts/Layout.astro'
import MetaTags from '@components/layout/MetaTags.astro'
import Breadcrumbs from '@components/layout/Breadcrumbs.astro'
import Container from '@components/layout/Container.astro'
import { SITE_MAP } from '@constants/site_map'
import { BUSINESS_INFO } from '@constants/business'

const page = SITE_MAP.find(p => p.slug === 'contacto')!
const { phone, email, whatsapp } = BUSINESS_INFO
---

<Layout>
  <MetaTags
    title={`Tutto a Leña | ${page.name}`}
    description={page.description}
    canonical={page.path}
  />
  <Breadcrumbs
    items={[
      { label: 'Inicio', href: '/' },
      { label: 'Contacto', href: '/contacto' },
    ]}
  />

  <!-- Hero Section -->
  <section class="py-12 md:py-16 bg-gradient-to-b from-primary/10 to-background border-b border-surface-border">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center space-y-4">
        <h1 class="font-display text-5xl md:text-6xl font-bold text-foreground">
          Contactanos
        </h1>
        <p class="text-xl text-muted max-w-2xl mx-auto">
          Estamos aquí para responderte. Comunicáte con nosotros por el medio que prefieras
        </p>
      </div>
    </div>
  </section>

  <Container>
    <div class="py-12 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <!-- Contacto Info -->
        <div class="space-y-6">
          <h2 class="font-display text-3xl font-bold text-foreground">
            Formas de contacto
          </h2>

          <!-- WhatsApp -->
          <a
            href={`https://wa.me/${whatsapp?.replace(/\D/g, '')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="group block bg-surface rounded-2xl border border-surface-border p-6 hover:border-primary hover:shadow-glow transition-all duration-300"
          >
            <div class="flex items-start gap-4">
              <div class="text-5xl flex-shrink-0">💬</div>
              <div>
                <h3 class="text-xl font-bold text-foreground group-hover:text-primary transition-colors mb-1">
                  WhatsApp
                </h3>
                <p class="text-primary font-semibold text-lg mb-1">{whatsapp}</p>
                <p class="text-sm text-muted-foreground">Respuesta rápida y contacto directo</p>
              </div>
            </div>
          </a>

          <!-- Teléfono -->
          <a
            href={`tel:${phone}`}
            class="group block bg-surface rounded-2xl border border-surface-border p-6 hover:border-primary hover:shadow-glow transition-all duration-300"
          >
            <div class="flex items-start gap-4">
              <div class="text-5xl flex-shrink-0">📞</div>
              <div>
                <h3 class="text-xl font-bold text-foreground group-hover:text-primary transition-colors mb-1">
                  Teléfono
                </h3>
                <p class="text-primary font-semibold text-lg mb-1">{phone}</p>
                <p class="text-sm text-muted-foreground">Llamadas de lunes a domingo</p>
              </div>
            </div>
          </a>

          <!-- Email -->
          <a
            href={`mailto:${email}`}
            class="group block bg-surface rounded-2xl border border-surface-border p-6 hover:border-primary hover:shadow-glow transition-all duration-300"
          >
            <div class="flex items-start gap-4">
              <div class="text-5xl flex-shrink-0">✉️</div>
              <div>
                <h3 class="text-xl font-bold text-foreground group-hover:text-primary transition-colors mb-1">
                  Email
                </h3>
                <p class="text-primary font-semibold break-all mb-1">{email}</p>
                <p class="text-sm text-muted-foreground">Respuesta en 24 horas</p>
              </div>
            </div>
          </a>

          <!-- Ubicación -->
          <a
            href="/donde-estamos"
            class="group block bg-gradient-to-br from-primary/10 to-primary/5 rounded-2xl border border-primary/20 p-6 hover:border-primary hover:shadow-glow transition-all duration-300"
          >
            <div class="flex items-start gap-4">
              <div class="text-5xl flex-shrink-0">📍</div>
              <div>
                <h3 class="text-xl font-bold text-foreground group-hover:text-primary transition-colors mb-1">
                  Visítanos
                </h3>
                <p class="text-muted-foreground text-sm mb-2">
                  Conoce nuestro espacio y disfruta de la experiencia de Tutto a Leña
                </p>
                <p class="text-primary font-semibold text-sm">Ver ubicación →</p>
              </div>
            </div>
          </a>
        </div>

        <!-- Formulario / Mensaje -->
        <div>
          <div class="bg-gradient-to-br from-primary/10 to-primary/5 rounded-2xl border border-primary/20 p-8 space-y-6">
            <div>
              <h2 class="font-display text-3xl font-bold text-foreground mb-2">
                ¿Qué necesitás?
              </h2>
              <p class="text-muted-foreground">Selecciona la opción que mejor describa tu consulta</p>
            </div>

            <div class="space-y-3">
              <a
                href={`https://wa.me/${whatsapp?.replace(/\D/g, '')}?text=Hola%2C%20quisiera%20consultar%20sobre%20catering`}
                target="_blank"
                rel="noopener noreferrer"
                class="block p-4 bg-surface rounded-lg border border-surface-border hover:border-primary hover:bg-primary/5 transition-all duration-300 text-foreground hover:text-primary font-semibold"
              >
                🍕 Consultar sobre catering
              </a>
              <a
                href={`https://wa.me/${whatsapp?.replace(/\D/g, '')}?text=Hola%2C%20quisiera%20conocer%20m%C3%A1s%20sobre%20vuestros%20eventos`}
                target="_blank"
                rel="noopener noreferrer"
                class="block p-4 bg-surface rounded-lg border border-surface-border hover:border-primary hover:bg-primary/5 transition-all duration-300 text-foreground hover:text-primary font-semibold"
              >
                🎉 Información sobre eventos
              </a>
              <a
                href={`https://wa.me/${whatsapp?.replace(/\D/g, '')}?text=Hola%2C%20tengo%20una%20consulta`}
                target="_blank"
                rel="noopener noreferrer"
                class="block p-4 bg-surface rounded-lg border border-surface-border hover:border-primary hover:bg-primary/5 transition-all duration-300 text-foreground hover:text-primary font-semibold"
              >
                ❓ Otra consulta
              </a>
            </div>

            <div class="bg-surface rounded-lg p-4 border border-surface-border">
              <p class="text-sm text-muted-foreground leading-relaxed">
                <strong class="text-foreground">Horario de atención:</strong><br />
                Lunes a viernes: 10:00 - 20:00 hs.<br />
                Sábados y domingos: 12:00 - 22:00 hs.
              </p>
            </div>
          </div>

          <!-- Quick Response Info -->
          <div class="mt-6 p-4 bg-primary/10 border border-primary/20 rounded-lg">
            <p class="text-sm text-primary font-semibold">
              💡 Tip: Responder más rápido via WhatsApp que por email
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA Section -->
    <section class="py-12 bg-gradient-to-r from-primary/10 to-primary/5 rounded-2xl border border-primary/20 text-center space-y-6">
      <h3 class="font-display text-3xl md:text-4xl font-bold text-foreground">
        ¿Querés saber dónde estamos?
      </h3>
      <p class="text-lg text-muted max-w-2xl mx-auto">
        Visítanos en nuestro espacio. Te esperamos de martes a domingo con las mejores pizzas a leña.
      </p>
      <a
        href="/donde-estamos"
        class="inline-flex items-center justify-center px-8 py-3 bg-primary text-primary-foreground font-bold rounded-full hover:bg-primary-hover transition-colors shadow-glow"
      >
        Ver Ubicación
      </a>
    </section>
  </Container>
</Layout>
