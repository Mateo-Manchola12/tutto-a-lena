---
import Layout from '@/layouts/Layout.astro'
import MetaTags from '@components/layout/MetaTags.astro'
import Breadcrumbs from '@components/layout/Breadcrumbs.astro'
import Container from '@components/layout/Container.astro'
import Section from '@components/layout/Section.astro'
import { SITE_MAP } from '@constants/site_map'
import { BUSINESS_INFO } from '@constants/business'
import Button from '@components/ui/Button.astro'

const page = SITE_MAP.find(p => p.slug === 'contacto')!
const { phone, email, whatsapp } = BUSINESS_INFO
---

<Layout>
  <MetaTags
    title={`Tutto a Leña | ${page.name}`}
    description={page.description}
    canonical={page.path}
  />
  <Container>
    <Breadcrumbs
      items={[
        { label: 'Inicio', href: '/' },
        { label: 'Contacto', href: '/contacto' },
      ]}
    />
    <Section title="Contacto" subtitle="Estamos para ayudarte">
      <div class="space-y-3">
        <p class="text-muted">Teléfono: {phone}</p>
        <p class="text-muted">Email: {email}</p>
        <p class="text-muted">WhatsApp: {whatsapp}</p>
        <div class="flex gap-3 mt-4">
          <Button href="/reservar" variant="primary">Reservar mesa</Button>
          <Button href="/catering" variant="outline">Solicitar catering</Button>
        </div>
      </div>
    </Section>
  </Container>
</Layout>
