---
import Layout from '@/layouts/Layout.astro'
import MetaTags from '@components/layout/MetaTags.astro'
import Breadcrumbs from '@components/layout/Breadcrumbs.astro'
import Container from '@components/layout/Container.astro'
import Section from '@components/layout/Section.astro'
import { SITE_MAP } from '@constants/site_map'
import { getMenuItemsByCategory } from '@constants/menu'

const page = SITE_MAP.find(p => p.slug === 'carta')!
const categories = [
  { id: 'pizzas', name: '🍕 Pizzas', emoji: '🍕' },
  { id: 'pasta', name: '🍝 Pastas', emoji: '🍝' },
  { id: 'carne', name: '🥩 Carnes', emoji: '🥩' },
  { id: 'entrada', name: '🍤 Entradas', emoji: '🍤' },
  { id: 'postre', name: '🍰 Postres', emoji: '🍰' },
  { id: 'bebida', name: '🍷 Bebidas', emoji: '🍷' },
]

const getCategoryId = (name: string) => {
  const map: Record<string, string> = {
    'pizzas': 'pizzas',
    'pastas': 'pasta',
    'carnes': 'carne',
    'entradas': 'entrada',
    'postres': 'postre',
    'bebidas': 'bebida',
  }
  return map[name] || name
}
---

<Layout>
  <MetaTags
    title={`Tutto a Leña | ${page.name}`}
    description={page.description}
    canonical={page.path}
  />
  <Container>
    <Breadcrumbs
      items={[
        { label: 'Inicio', href: '/' },
        { label: 'Carta', href: '/carta' },
      ]}
    />
  </Container>

  <!-- Hero Section -->
  <section class="py-12 md:py-16 bg-gradient-to-b from-primary/10 to-background border-b border-surface-border">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center space-y-4">
        <h1 class="font-display text-5xl md:text-6xl font-bold text-foreground">
          Nuestra <span class="text-primary">Carta</span>
        </h1>
        <p class="text-xl text-muted max-w-2xl mx-auto">
          Ingredientes frescos, masa madre fermentada 48 horas y horno a leña a 800°C
        </p>
      </div>
    </div>
  </section>

  <Container>
    <!-- Tabs Navigation -->
    <div class="py-8">
      <div class="flex flex-wrap gap-2 md:gap-4 justify-center mb-12">
        {
          categories.map((cat) => (
            <a
              href={`#${cat.id}`}
              class="inline-flex items-center gap-2 px-4 md:px-6 py-2 md:py-3 rounded-full border-2 border-surface-border hover:border-primary text-foreground hover:text-primary hover:bg-primary/5 transition-all duration-300 font-semibold"
            >
              <span class="text-xl">{cat.emoji}</span>
              <span class="hidden sm:inline">{cat.name.split(' ')[1]}</span>
            </a>
          ))
        }
      </div>
    </div>

    <!-- Categorias -->
    <div class="space-y-16 pb-16">
      {
        categories.map((category) => {
          const categoryId = getCategoryId(category.id)
          const items = getMenuItemsByCategory(categoryId as any)
          return (
            <section id={category.id} class="scroll-mt-20">
              <!-- Category Header -->
              <div class="mb-8 pb-6 border-b-2 border-primary/30">
                <h2 class="font-display text-4xl md:text-5xl font-bold text-foreground">
                  <span class="text-3xl md:text-4xl">{category.emoji}</span> {category.name}
                </h2>
                <p class="text-muted mt-2">
                  {category.id === 'pizzas' && 'Horneadas a 800°C en nuestro horno a leña artesanal'}
                  {category.id === 'pasta' && 'Elaboradas con ingredientes frescos y técnicas tradicionales italianas'}
                  {category.id === 'carne' && 'Carnes premium preparadas a la parrilla y en horno'}
                  {category.id === 'entrada' && 'Perfectas para comenzar tu experiencia gastronómica'}
                  {category.id === 'postre' && 'Dulces finales para completar tu experiencia'}
                  {category.id === 'bebida' && 'Bebidas que complementan perfectamente tu comida'}
                </p>
              </div>

              <!-- Items Grid -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                {items.map((item) => (
                  <div class="group bg-surface rounded-2xl border border-surface-border p-6 hover:border-primary hover:shadow-glow transition-all duration-300 transform hover:scale-105">
                    <!-- Header con nombre y precio -->
                    <div class="flex items-start justify-between gap-4 mb-3">
                      <div class="flex-1">
                        <h3 class="text-xl md:text-2xl font-bold text-foreground group-hover:text-primary transition-colors">
                          {item.name}
                        </h3>
                        {item.tags && item.tags.length > 0 && (
                          <div class="flex flex-wrap gap-1 mt-2">
                            {item.tags.map((tag) => (
                              <span class="inline-block px-2 py-1 bg-primary/10 text-primary text-xs font-semibold rounded-full">
                                {tag === 'popular' && '⭐ Popular'}
                                {tag === 'nuevo' && '✨ Nuevo'}
                                {tag === 'especialidad' && '🎯 Especialidad'}
                                {tag === 'premium' && '👑 Premium'}
                                {tag === 'vegetariano' && '🌱 Vegetariano'}
                                {tag === 'picante' && '🌶️ Picante'}
                                {tag === 'mariscos' && '🦐 Mariscos'}
                                {tag === 'argentino' && '🇦🇷 Argentino'}
                                {tag === 'italiano' && '🇮🇹 Italiano'}
                                {tag === 'clasico' && '⏰ Clásico'}
                                {tag === 'casero' && '🏡 Casero'}
                                {tag === 'para-compartir' && '👥 Compartir'}
                                {tag === 'estacional' && '🍂 Estacional'}
                                {!['popular', 'nuevo', 'especialidad', 'premium', 'vegetariano', 'picante', 'mariscos', 'argentino', 'italiano', 'clasico', 'casero', 'para-compartir', 'estacional'].includes(tag) && (
                                  <span>{tag}</span>
                                )}
                              </span>
                            ))}
                          </div>
                        )}
                      </div>
                      <div class="flex-shrink-0 text-right">
                        <div class="text-2xl md:text-3xl font-bold text-primary">
                          ${item.price?.toFixed(2) ?? '--'}
                        </div>
                      </div>
                    </div>

                    <!-- Descripción -->
                    <p class="text-muted-foreground leading-relaxed mb-4">
                      {item.description}
                    </p>

                    <!-- Ingredientes -->
                    {item.ingredients && item.ingredients.length > 0 && (
                      <div class="pt-4 border-t border-surface-border">
                        <p class="text-xs uppercase text-muted font-semibold mb-2">Ingredientes:</p>
                        <p class="text-sm text-muted-foreground">
                          {item.ingredients.join(', ')}
                        </p>
                      </div>
                    )}
                  </div>
                ))}
              </div>
            </section>
          )
        })
      }
    </div>

    <!-- Call to Action -->
    <section class="py-12 bg-gradient-to-r from-primary/10 to-primary/5 rounded-2xl border border-primary/20 text-center space-y-6 mb-12">
      <h3 class="font-display text-3xl md:text-4xl font-bold text-foreground">
        ¿Qué esperas para visitarnos?
      </h3>
      <p class="text-lg text-muted max-w-2xl mx-auto">
        Reserva tu mesa ahora y vive una experiencia gastronómica única. Atendemos de martes a domingo de 12:00 a 23:00 hs.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/reservar"
          class="inline-flex items-center justify-center px-8 py-3 bg-primary text-primary-foreground font-bold rounded-full hover:bg-primary-hover transition-colors shadow-glow"
        >
          Reservar Mesa
        </a>
        <a
          href="/contacto"
          class="inline-flex items-center justify-center px-8 py-3 border-2 border-primary text-primary font-bold rounded-full hover:bg-primary/10 transition-colors"
        >
          Contáctanos
        </a>
      </div>
    </section>
  </Container>
</Layout>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
