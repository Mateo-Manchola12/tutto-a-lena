---
import Layout from '@/layouts/Layout.astro'
import Breadcrumbs from '@components/layout/Breadcrumbs.astro'
import Container from '@components/layout/Container.astro'
import Button from '@components/ui/Button.astro'
import { BusinessInfo } from '@constants/business'
import { formatEventDate, getUpcomingEvents } from '@constants/events'

const businessInfo = await BusinessInfo.getInfo()
const events = await getUpcomingEvents()
---

<Layout>
  <Breadcrumbs
    items={[
      { label: 'Inicio', href: '/' },
      { label: 'Eventos', href: '/eventos' },
    ]}
  />

  <!-- Hero Section -->
  <section class="py-12 md:py-16 bg-linear-to-b from-primary/10 to-background border-b border-surface-border">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center space-y-4">
        <h1 class="font-display text-5xl md:text-6xl font-bold text-foreground">
          Próximos <span class="text-primary">Eventos</span>
        </h1>
        <p class="text-xl text-muted max-w-2xl mx-auto">
          Vive experiencias únicas en Tutto a Leña. Eventos especiales, catas y encuentros gastronómicos
        </p>
      </div>
    </div>
  </section>

  <Container>
    <div class="py-12 md:py-16">
      {events.length > 0 ? (
        <>
          <!-- Eventos Grid -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
            {
              events.map((ev) => (
                <div class="group bg-surface rounded-2xl border border-surface-border overflow-hidden hover:border-primary hover:shadow-glow transition-all duration-300 transform hover:scale-105">
                  <!-- Header con fecha -->
                  <div class="bg-linear-to-r from-primary to-primary/80 text-white p-4">
                    <p class="text-sm font-semibold opacity-90">📅 {formatEventDate(ev.date)}</p>
                    <p class="text-sm opacity-75">⏰ {ev.startTime}{ev.endTime ? ` - ${ev.endTime}` : ''}</p>
                    <p class="text-sm opacity-75">📍 {ev.location}</p>
                  </div>

                  <!-- Contenido -->
                  <div class="p-6 space-y-3">
                    <h3 class="text-2xl font-bold text-foreground group-hover:text-primary transition-colors">
                      {ev.title}
                    </h3>
                    <p class="text-muted-foreground leading-relaxed">{ev.description}</p>

                    <!-- CTA -->
                    <div class="pt-4 border-t border-surface-border">
                      <Button
                        href={ev.cta?.url ?? businessInfo.cta.contact}
                        variant="ghost"
                        size="sm"
                        class="text-primary font-semibold px-0 hover:px-0"
                      >
                        {ev.cta?.label ?? 'Consultar más'} →
                      </Button>
                    </div>
                  </div>
                </div>
              ))
            }
          </div>
        </>
      ) : (
        <div class="text-center py-16 bg-surface rounded-2xl border border-surface-border">
          <div class="text-5xl mb-4">🎪</div>
          <h3 class="font-display text-2xl font-bold text-foreground mb-2">Sin eventos programados</h3>
          <p class="text-muted-foreground max-w-md mx-auto mb-6">
            Estamos preparando nuevas experiencias. Seguinos en redes sociales para no perderte los próximos eventos.
          </p>
          <Button href={businessInfo.cta.contact} variant="outline" size="md" class="font-semibold">
            Consultar
          </Button>
        </div>
      )}

      <!-- Tipos de Eventos -->
      <section class="py-12 md:py-16">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground text-center mb-12">
          Eventos que organizamos
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {
            [
              {
                icon: '🍷',
                title: 'Catas de Vino y Comida',
                description: 'Maridajes especiales con nuestras pizzas y embutidos italianos premium.',
              },
              {
                icon: '👨‍🍳',
                title: 'Experiencias Culinarias',
                description: 'Cocina en vivo, demostración de hornado y conocimiento de técnicas tradicionales.',
              },
              {
                icon: '🎉',
                title: 'Cenas Especiales',
                description: 'Encuentros gastronómicos cerrados con menú degustación exclusivo.',
              },
              {
                icon: '📚',
                title: 'Talleres de Pizza',
                description: 'Aprende a hacer pizzas auténticas con nuestros pizzaiolos certificados.',
              },
              {
                icon: '🎭',
                title: 'Eventos Temáticos',
                description: 'Noches italianas, celebraciones especiales y encuentros temáticos.',
              },
              {
                icon: '🤝',
                title: 'Encuentros Corporativos',
                description: 'Team building, networking y eventos empresariales con catering premium.',
              },
            ].map((event) => (
              <div class="bg-surface rounded-2xl border border-surface-border p-6 hover:border-primary hover:shadow-glow transition-all duration-300">
                <div class="text-4xl mb-4">{event.icon}</div>
                <h3 class="text-xl font-bold text-foreground mb-2">{event.title}</h3>
                <p class="text-muted-foreground">{event.description}</p>
              </div>
            ))
          }
        </div>
      </section>

      <!-- CTA Final -->
      <section class="py-12 bg-linear-to-r from-primary to-primary/90 rounded-2xl text-center space-y-6 text-white">
        <h3 class="font-display text-3xl md:text-4xl font-bold">
          ¿Querés organizar un evento?
        </h3>
        <p class="text-lg text-white/90 max-w-2xl mx-auto">
          Cuéntanos tu idea. Nosotros nos encargamos del resto para hacer un evento inolvidable.
        </p>
        <Button
          href={businessInfo.cta.contact}
          variant="primary"
          size="lg"
          class="bg-white text-primary! hover:text-primary-foreground! hover:bg-gray-100 active:bg-gray-200 shadow-lg font-bold"
        >
          Contactanos
        </Button>
      </section>
    </div>
  </Container>
</Layout>
